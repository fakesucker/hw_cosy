# Normalize line endings for cross-platform collaboration
* text=auto

*.sh   text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.lst  text eol=lf
*.tsv  text eol=lf
*.csv  text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.wav  binary
*.pt   binary
*.onnx binary
